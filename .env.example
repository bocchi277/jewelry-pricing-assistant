# Copy this file to .env and fill in your own key. .env is gitignored --
# never commit your real key.

# Get a free key at https://aistudio.google.com/app/apikey (no credit card
# required as of mid-2026). Without this set, the tool still runs fine --
# it just uses deterministic template text instead of Gemini-generated
# prose for pricing_explanation / validation_warnings.
GEMINI_API_KEY=your-api-key-here

# Optional. Primary model -- defaults to gemini-3.1-flash-lite if not set.
# This is the first model tried for every AI call.
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional. Fallback model -- tried when the primary model fails (rate
# limit, network error, etc.). Defaults to gemini-2.5-flash if not set.
# Note: gemini-2.5-flash has a 5 req/min free-tier rate limit; the tool
# automatically throttles to stay under it.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
